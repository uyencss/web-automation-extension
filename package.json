{
  "name": "webmcp-browser-automation-kit",
  "version": "1.0.0",
  "private": true,
  "description": "Reusable WebMCP Chrome extension, gateway, and agent skill kit for browser automation.",
  "scripts": {
    "setup": "npm --prefix server install",
    "gateway": "npm --prefix server run gateway",
    "health": "node scripts/webmcp-call.js ping",
    "call": "node scripts/webmcp-call.js",
    "tools:generate": "node scripts/generate-tool-reference.js",
    "tools:check": "node scripts/generate-tool-reference.js --check"
  },
  "engines": {
    "node": ">=18"
  }
}
